<?xml version="1.0" encoding="UTF-8"?>
<config xmlns="http://www.ehcache.org/v3"
        xmlns:jsr107="http://www.ehcache.org/v3/jsr107">

    <!-- デフォルト設定 -->
    <cache alias="default">
        <resources>
            <heap unit="entries">1000</heap>
            <offheap unit="MB">100</offheap>
        </resources>
        <expiry>
            <ttl unit="hours">1</ttl>
        </expiry>
    </cache>

    <!-- ユーザープロファイルキャッシュ -->
    <cache alias="user-profile">
        <resources>
            <heap unit="entries">500</heap>
            <offheap unit="MB">50</offheap>
        </resources>
        <expiry>
            <ttl unit="minutes">30</ttl>
        </expiry>
    </cache>

    <!-- 申請データキャッシュ -->
    <cache alias="application-data">
        <resources>
            <heap unit="entries">2000</heap>
            <offheap unit="MB">200</offheap>
        </resources>
        <expiry>
            <ttl unit="minutes">15</ttl>
        </expiry>
    </cache>

    <!-- 参照データキャッシュ -->
    <cache alias="reference-data">
        <resources>
            <heap unit="entries">100</heap>
            <offheap unit="MB">20</offheap>
        </resources>
        <expiry>
            <ttl unit="hours">24</ttl>
        </expiry>
    </cache>

    <!-- Hibernate エンティティキャッシュ -->
    <cache alias="com.medicalcare.domain.entity.User">
        <resources>
            <heap unit="entries">1000</heap>
            <offheap unit="MB">100</offheap>
        </resources>
        <expiry>
            <ttl unit="hours">1</ttl>
        </expiry>
    </cache>

    <cache alias="com.medicalcare.domain.entity.Application">
        <resources>
            <heap unit="entries">2000</heap>
            <offheap unit="MB">200</offheap>
        </resources>
        <expiry>
            <ttl unit="minutes">30</ttl>
        </expiry>
    </cache>

    <cache alias="com.medicalcare.domain.Document">
        <resources>
            <heap unit="entries">1000</heap>
            <offheap unit="MB">100</offheap>
        </resources>
        <expiry>
            <ttl unit="hours">2</ttl>
        </expiry>
    </cache>

    <!-- Hibernate クエリキャッシュ -->
    <cache alias="org.hibernate.cache.internal.StandardQueryCache">
        <resources>
            <heap unit="entries">500</heap>
            <offheap unit="MB">50</offheap>
        </resources>
        <expiry>
            <ttl unit="minutes">10</ttl>
        </expiry>
    </cache>

    <cache alias="org.hibernate.cache.spi.UpdateTimestampsCache">
        <resources>
            <heap unit="entries">100</heap>
            <offheap unit="MB">10</offheap>
        </resources>
        <expiry>
            <ttl unit="minutes">5</ttl>
        </expiry>
    </cache>

    <!-- JSR-107 設定 -->
    <service>
        <jsr107:defaults enable-management="true" enable-statistics="true">
            <jsr107:cache name="user-profile" template="user-profile"/>
            <jsr107:cache name="application-data" template="application-data"/>
            <jsr107:cache name="reference-data" template="reference-data"/>
        </jsr107:defaults>
    </service>

</config> 